local function cleanCF(cf)
    local x, y, z = math.floor(cf.X * 1000 + 0.5) / 1000, math.floor(cf.Y * 1000 + 0.5) / 1000, math.floor(cf.Z * 1000 + 0.5) / 1000
    return CFrame.new(x, y, z) * (cf - cf.Position)
end

local function applyWoodStyle(part, woodType)
    if WC[woodType] then part.Color = WC[woodType] end
    part.Material = Enum.Material.Wood
    if woodType == "Spooky" then part.Material = Enum.Material.Granite 
    elseif woodType == "SpookyNeon" then part.Material = Enum.Material.Neon end
    part.Transparency = 0.5; part.Anchored = true; part.CanCollide = false
end

local function getPermutations(v)
    local angles = {
        CFrame.Angles(0, 0, 0), CFrame.Angles(0, math.rad(90), 0),
        CFrame.Angles(math.rad(90), 0, 0), CFrame.Angles(0, 0, math.rad(90)),
        CFrame.Angles(math.rad(90), math.rad(90), 0), CFrame.Angles(math.rad(90), 0, math.rad(90))
    }
    local perms, seen = {}, {}
    for i, rot in ipairs(angles) do
        local rotatedVec = rot * v
        local newSize = Vector3.new(math.floor(math.abs(rotatedVec.X) * 1000 + 0.5) / 1000, math.floor(math.abs(rotatedVec.Y) * 1000 + 0.5) / 1000, math.floor(math.abs(rotatedVec.Z) * 1000 + 0.5) / 1000)
        local key = newSize.X .. "_" .. newSize.Y .. "_" .. newSize.Z
        if not seen[key] then seen[key] = true table.insert(perms, {Size = newSize, Rot = rot, IsBase = (i == 1)}) end
    end
    return perms
end

local function fillVolume(targetSize)
    local allowed = {} for _, bp in ipairs(availableBlueprints) do if not excludedBlueprints[bp.Name] then table.insert(allowed, bp) end end
    local spaces, placed = {{Min = Vector3.zero, Max = targetSize}}, {}
    local function spaceSize(s) return s.Max - s.Min end

    while #spaces > 0 do
        local space = table.remove(spaces, 1) local sSize = spaceSize(space)
        local bestBp, bestPermInfo, bestScore = nil, nil, -1

        for _, bp in ipairs(allowed) do
            for _, permInfo in ipairs(getPermutations(bp.Size)) do
                local perm = permInfo.Size
                if perm.X <= sSize.X + 0.05 and perm.Y <= sSize.Y + 0.05 and perm.Z <= sSize.Z + 0.05 then
                    local score = (perm.X * perm.Y * perm.Z) * 1000 
                    if permInfo.IsBase then score = score + 50 end
                    local lName = string.lower(bp.Name)
                    if sSize.Y <= 1.1 and string.find(lName, "floor") then score = score + 50000 
                    elseif sSize.Y >= 2.0 and string.find(lName, "wall") then score = score + 5000 end
                    if score > bestScore then bestScore, bestBp, bestPermInfo = score, bp, permInfo end
                end
            end
        end

        if bestBp then
            local perm = bestPermInfo.Size
            table.insert(placed, { OriginalSize = bestBp.Size, Position = space.Min + perm / 2, BP_Name = bestBp.Name, Rot = bestPermInfo.Rot })
            local w, h, d = perm.X, perm.Y, perm.Z
            local W, H, D = sSize.X, sSize.Y, sSize.Z
            local function addSpace(s) if spaceSize(s).X >= 0.15 and spaceSize(s).Y >= 0.15 and spaceSize(s).Z >= 0.15 then table.insert(spaces, s) end end
            addSpace({Min = space.Min + Vector3.new(w, 0, 0), Max = space.Min + Vector3.new(W, h, d)})
            addSpace({Min = space.Min + Vector3.new(0, h, 0), Max = space.Min + Vector3.new(W, H, d)})
            addSpace({Min = space.Min + Vector3.new(0, 0, d), Max = space.Max})
        end
        if #placed > 800 then break end 
    end
    return placed
end

local function rebuildVisuals(model)
    local bbox, visuals = model:FindFirstChild("BoundingBox"), model:FindFirstChild("Visuals")
    if not bbox or not visuals then return end
    visuals:ClearAllChildren()
    local placedBlocks, woodType = fillVolume(bbox.Size), model:GetAttribute("WoodType") or "Generic"
    
    if #placedBlocks == 0 then
        local p = Instance.new("Part", visuals) p.Size = bbox.Size p.CFrame = bbox.CFrame p.Color = Color3.fromRGB(255, 50, 50) p.Material = Enum.Material.Neon p.Transparency = 0.5 p.Anchored = true p.CanCollide = false
        local out = Instance.new("SelectionBox", p) out.Adornee = p out.Color3 = Color3.fromRGB(255, 0, 0) out.LineThickness = 0.05 return
    end
    local cornerCF = bbox.CFrame * CFrame.new(-bbox.Size.X/2, -bbox.Size.Y/2, -bbox.Size.Z/2)
    for _, blk in ipairs(placedBlocks) do
        local p = Instance.new("Part", visuals) p.Size = blk.OriginalSize p.CFrame = cornerCF * CFrame.new(blk.Position) * (blk.Rot or CFrame.identity)
        p:SetAttribute("BP_Name", blk.BP_Name) p:SetAttribute("WoodType", woodType) applyWoodStyle(p, woodType)
        local out = Instance.new("SelectionBox", p) out.Adornee = p out.Color3 = WC[woodType] or Color3.new(1,1,1) out.LineThickness = 0.03
    end
end

local function placeBaseBlock(cframe, size, woodType)
    local model = Instance.new("Model") model:SetAttribute("WoodType", woodType)
    local bbox = Instance.new("Part", model) bbox.Name = "BoundingBox" bbox.Size = size bbox.CFrame = cframe bbox.Transparency = 1 bbox.Anchored = true bbox.CanCollide = false
    model.PrimaryPart = bbox
    local visuals = Instance.new("Folder", model) visuals.Name = "Visuals"
    model.Parent = plannedBuildsFolder rebuildVisuals(model)
end

_G.LT2_LoadSave = function(encodedStr)
    if type(encodedStr) ~= "string" or #encodedStr < 4 then return end
    local shift = tonumber(string.sub(encodedStr, 1, 2), 16)
    local mult = tonumber(string.sub(encodedStr, 3, 4), 16)
    local dataStr = ""
    for i = 5, #encodedStr, 4 do
        local chunk = string.sub(encodedStr, i, i + 3)
        local val = tonumber(chunk, 16)
        if val then dataStr = dataStr .. string.char((val / mult) - shift) end
    end
    for blockStr in string.gmatch(dataStr, "([^;]+)") do
        local p = string.split(blockStr, "|")
        if #p >= 10 then
            local wType = p[1]
            local size = Vector3.new(tonumber(p[2]), tonumber(p[3]), tonumber(p[4]))
            local cf = CFrame.new(tonumber(p[5]), tonumber(p[6]), tonumber(p[7])) * CFrame.Angles(tonumber(p[8]), tonumber(p[9]), tonumber(p[10]))
            placeBaseBlock(cf, size, wType)
        end
    end
    print("✅ Build successfully loaded!")
end

