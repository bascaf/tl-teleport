local function isValidWoodSize(size) return math.max(size.X, size.Y, size.Z) <= 3.5 and math.min(size.X, size.Y, size.Z) >= 0.1 end

btnBuild.MouseButton1Click:Connect(function()
    btnBuild.Text = "CALCULATING..."
    local planned = {}
    for _, model in pairs(plannedBuildsFolder:GetChildren()) do
        local visuals = model:FindFirstChild("Visuals")
        if visuals then
            for _, part in pairs(visuals:GetChildren()) do
                if part.Color ~= Color3.fromRGB(255, 50, 50) then 
                    table.insert(planned, { bpName = part:GetAttribute("BP_Name"), cframe = cleanCF(part.CFrame), woodType = model:GetAttribute("WoodType") or "Generic", visualPart = part })
                end
            end
        end
    end
    if #planned == 0 then btnBuild.Text = "NO BLUEPRINTS" task.wait(2) btnBuild.Text = "START: BUILD" return end

    local availableWood = {}
    for _, v in pairs(workspace.PlayerModels:GetChildren()) do
        if v:FindFirstChild("WoodSection") and v:FindFirstChild("Owner") and v.Owner.Value == player and isValidWoodSize(v.WoodSection.Size) then 
            table.insert(availableWood, {model = v, primary = v.WoodSection, woodType = (v:FindFirstChild("TreeClass") and v.TreeClass.Value or "Generic"), used = false}) 
        end
    end
    
    local requiredWoodCounts, foundWoodCounts = {}, {}
    for _, plan in ipairs(planned) do requiredWoodCounts[plan.woodType] = (requiredWoodCounts[plan.woodType] or 0) + 1 end
    for _, w in ipairs(availableWood) do foundWoodCounts[w.woodType] = (foundWoodCounts[w.woodType] or 0) + 1 end

    for wType, count in pairs(requiredWoodCounts) do
        local found = foundWoodCounts[wType] or 0
        if found < count then
            btnBuild.Text = "❌ NOT ENOUGH: " .. string.upper(wType) btnBuild.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            warn("❌ ERROR: Need " .. count .. " pieces of " .. wType .. ", but only found " .. found .. "!")
            task.wait(3) btnBuild.Text = "START: BUILD" btnBuild.BackgroundColor3 = Color3.fromRGB(50, 150, 50) return
        end
    end
    
