local isDraggingPlan, planOffsets, dragPlanRenderConn = false, {}, nil

local keyConn = UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if isTool6Eq and input.UserInputType == Enum.UserInputType.MouseButton1 then isPainting = true end
    
    if isTool2Eq and input.UserInputType == Enum.UserInputType.MouseButton1 then
        if previewPart.Parent and mouse.Hit then placeBaseBlock(previewPart.CFrame, previewPart.Size, currentWoodType) end
    end

    if (isTool3Eq or isTool4Eq) and input.UserInputType == Enum.UserInputType.MouseButton1 then
        local target = mouse.Target
        if target and target:IsDescendantOf(plannedBuildsFolder) then
            currentAdorneeModel = target:FindFirstAncestorWhichIsA("Model")
            if currentAdorneeModel and currentAdorneeModel:FindFirstChild("BoundingBox") then
                if isTool3Eq then resizeHandles.Adornee = currentAdorneeModel.BoundingBox end
                if isTool4Eq then 
                    if currentTool4Mode == "Rotate" then arcHandles.Adornee = currentAdorneeModel.BoundingBox moveHandles.Adornee = nil
                    else moveHandles.Adornee = currentAdorneeModel.BoundingBox arcHandles.Adornee = nil end
                end
            end
        else
            if isTool3Eq then resizeHandles.Adornee = nil end
            if isTool4Eq then arcHandles.Adornee = nil moveHandles.Adornee = nil end
            currentAdorneeModel = nil
        end
    end
    
    if input.KeyCode == Enum.KeyCode.X then
        local tools = {tool1, tool2, tool3, tool4, tool5, tool6, tool7}
        for _, t in ipairs(tools) do if t then t:Destroy() end end
        if guiManager then guiManager:Destroy() end if guiHammer then guiHammer:Destroy() end
        if handlesGui then handlesGui:Destroy() end if arcGui then arcGui:Destroy() end
        if screwGui then screwGui:Destroy() end if autoGui then autoGui:Destroy() end
        if saveGui then saveGui:Destroy() end
        if plannedBuildsFolder then plannedBuildsFolder:Destroy() end
        keyConn:Disconnect() return
    end
    
    if input.KeyCode == Enum.KeyCode.R and (isTool2Eq or isTool6Eq) then
        local idx = table.find(woodTypesList, currentWoodType) or 1
        currentWoodType = woodTypesList[(idx % #woodTypesList) + 1]
        woodLabel.Text = (isTool6Eq and "Brush: " or "Wood: ") .. currentWoodType .. "\n[R] Switch"
    end

    if input.KeyCode == Enum.KeyCode.P then
        if not isDraggingPlan then
            local minX, minY, minZ = math.huge, math.huge, math.huge
            local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
            local count = 0

            for _, model in ipairs(plannedBuildsFolder:GetChildren()) do
                if model.PrimaryPart then
                    local pos = model.PrimaryPart.Position
                    if pos.X < minX then minX = pos.X end if pos.Y < minY then minY = pos.Y end if pos.Z < minZ then minZ = pos.Z end
                    if pos.X > maxX then maxX = pos.X end if pos.Y > maxY then maxY = pos.Y end if pos.Z > maxZ then maxZ = pos.Z end
                    count = count + 1
                end
            end

            if count > 0 then
                local centerX, centerZ = math.floor((minX + maxX) / 2) + 0.5, math.floor((minZ + maxZ) / 2) + 0.5
                local originalCenter = CFrame.new(centerX, minY, centerZ)
                
                planOffsets = {}
                for _, model in ipairs(plannedBuildsFolder:GetChildren()) do
                    if model.PrimaryPart then planOffsets[model] = originalCenter:ToObjectSpace(model.PrimaryPart.CFrame) end
                end
                
                isDraggingPlan = true
                mouse.TargetFilter = plannedBuildsFolder
                
                dragPlanRenderConn = RunService.RenderStepped:Connect(function()
                    if mouse.Hit then
                        local pos = mouse.Hit.Position
                        local newCenter = CFrame.new(math.floor(pos.X) + 0.5, math.floor(pos.Y) + 0.5, math.floor(pos.Z) + 0.5)
                        for model, offset in pairs(planOffsets) do
                            if model and model.Parent then model:PivotTo(newCenter * offset) end
                        end
                    end
                end)
            end
        else
            isDraggingPlan = false
            if dragPlanRenderConn then dragPlanRenderConn:Disconnect() end
            mouse.TargetFilter = (isTool2Eq and previewPart) or nil
        end
    end

    if isDraggingPlan and input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingPlan = false
        if dragPlanRenderConn then dragPlanRenderConn:Disconnect() end
        mouse.TargetFilter = (isTool2Eq and previewPart) or nil
    end

    if isDraggingPlan and input.KeyCode == Enum.KeyCode.R then
        local rot = CFrame.Angles(0, math.rad(90), 0)
        for model, offset in pairs(planOffsets) do planOffsets[model] = rot * offset end
    end
end)

